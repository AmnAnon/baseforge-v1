exports[`ProtocolCompareSection > matches snapshot in initial state > ProtocolCompareSection-initial 1`] = `"<section class="space-y-6" aria-labelledby="compare-heading"><div class="flex items-start justify-between"><div><h2 id="compare-heading" class="text-2xl font-bold text-white">Protocol Comparison</h2><p class="text-sm text-gray-400">Side-by-side metric comparison</p></div></div><div class="grid grid-cols-2 gap-4"><select class="bg-black/50 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-white focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500"><option value="" class="bg-gray-900">Select Protocol A</option></select><select class="bg-black/50 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-white focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500"><option value="" class="bg-gray-900">Select Protocol B</option></select></div><div class="rounded-xl border text-card-foreground shadow p-8 bg-gray-900/60 border-gray-800 text-center"><p class="text-gray-400">Select two protocols to compare</p></div></section>"`;
