# ============================================
# BaseForge Analytics — Environment Variables
# ============================================
# Copy this to .env.local (never commit .env.local)

# ------------
# Required — APIs
# ------------

# Etherscan V2 (multi-chain, includes Base chainId 8453) — for whale tracking
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ------------
# Required — Database
# ------------

# Neon Postgres connection string (risk history, alerts, portfolio)
# Get one at https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/baseforge?sslmode=require

# ------------
# Required — Monitoring
# ------------

# Sentry DSN for error tracking (production)
# Get one at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://<key>@sentry.io/<project>

# -------------
# Optional — Cache
# -------------

# Cache backend: "memory" (default) or "upstash" (distributed, multi-instance safe)
CACHE_BACKEND=memory

# Upstash Redis (uncomment to swap from in-memory to Redis)
# UPSTASH_REDIS_URL=https://your-db.upstash.io
# UPSTASH_REDIS_TOKEN=your_token_here

# --------------
# Optional — Monitoring (CI only)
# --------------

# Sentry Auth Token (for source map uploads during build)
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Sentry org/project identifiers (for sourcemaps)
SENTRY_ORG=
SENTRY_PROJECT=

# --------------
# Optional — App URLs
# --------------

# Vercel deployment URL (auto-set on Vercel deploy)
VERCEL_URL=

# Custom domain or deployment URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------
# Optional — Logging
# --------------

# Log level: debug | info | warn | error
LOG_LEVEL=info

# --------------
# Optional — Whale Tracking Threshold
# --------------

# Minimum USD value to consider a transaction "whale" activity
WHALE_THRESHOLD_USD=50000

# --------------
# Optional — Farcaster Frame
# --------------

FC_FRAME_URL=https://your-app.vercel.app
FC_BOT_MNEMONIC=your_bot_mnemonic_here

# --------------
# Internal Defaults (do not change)
# --------------

# Base chain ID (EIP-155)
BASE_CHAIN_ID=8453
