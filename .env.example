# ============================================
# BaseForge Analytics — Environment Variables
# ============================================
# Copy this to .env.local (never commit .env.local)

# ------------
# APIs
# ------------

# Etherscan V2 (multi-chain, includes Base chainId 8453)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Base chain ID (EIP-155)
BASE_CHAIN_ID=8453

# ------------
# Database (Postgres) — Neon, Supabase, Railway
# ------------
DATABASE_URL=postgresql://user:password@host:5432/baseforge

# ------------
# Cache Backend
# ------------

# Set to "memory" (default) or "upstash"
CACHE_BACKEND=memory

# Upstash Redis (uncomment to swap from memory → Redis)
# UPSTASH_REDIS_URL=https://your-db.upstash.io
# UPSTASH_REDIS_TOKEN=your_token_here

# ------------
# App URLs
# ------------

# Vercel deployment URL (auto-set on Vercel)
VERCEL_URL=

# Custom domain (optional)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# App URL (alternative - NEXT_PUBLIC_BASE_URL takes precedence)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------
# Monitoring
# ------------

# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://<key>@sentry.io/<project>

# Sentry Auth Token for source map uploads
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Sentry Organization and Project (for sourcemaps)
SENTRY_ORG=
SENTRY_PROJECT=

# ------------
# Logging
# ------------
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ------------
# Whale Tracking
# ------------
WHALE_THRESHOLD=50000

# ------------
# Farcaster Frame
# ------------
FC_FRAME_URL=https://your-app.vercel.app
FC_BOT_MNEMONIC=your_bot_mnemonic_here

# ------------
# Thresholds
# ------------
WHALE_THRESHOLD_USD=50000
MIN_LIQUIDITY_USD=10000
