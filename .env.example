# ============================================
# BaseForge Analytics — Environment Variables
# ============================================
# Copy this file:  cp .env.example .env.local
# Never commit .env.local
#
# Variables documented below are the ones actually read by the codebase.
# NODE_ENV is set automatically by Next.js.

# ─── Required ─────────────────────────────

# Etherscan V2 API key — fallback whale tracking when Envio is unavailable
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Database — Neon Postgres for risk history, alerts, portfolio saves
# Get one at https://console.neon.tech
DATABASE_URL=

# ─── Required — Indexer (Primary Data Source) ──

# Envio HyperSync API token — primary on-chain data indexer
# 2000x faster than RPC, real-time event streaming from Base chain.
# Get one at https://envio.dev
ENVIO_API_TOKEN=

# Sentry DSN — client-side error tracking (production)
# Get one at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=

# Deployment URL — used for OG image absolute URLs, Frame URL, etc.
# Set to your actual deployment host (Vercel, Railway, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Optional — Cache ──────────────────────

# Switch from in-memory cache to Upstash Redis (default: "memory")
CACHE_BACKEND=memory

# Upstash Redis connection (required when CACHE_BACKEND=upstash)
# UPSTASH_REDIS_URL=https://your-db.upstash.io
# UPSTASH_REDIS_TOKEN=your_token_here

# ─── Optional — Logging ────────────────────

# Log level in code: debug | info | warn | error (default: "info")
LOG_LEVEL=info

# ─── Optional — Sentry build-time ──────────

# Auth token used during build to upload source maps to Sentry.
# Only needed in CI; set SENTRY_ORG and SENTRY_PROJECT in your project settings.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Optional — Social / Farcaster ─────────

# Neynar API key for Farcaster social data (casts, farcasters, frame analytics)
# Get one at https://docs.neynar.com
NEYNAR_API_KEY=

# Frame URL and bot mnemonic for Farcaster Frame V2
FC_FRAME_URL=https://your-app.vercel.app
FC_BOT_MNEMONIC=

# Farcaster accountAssociation for domain verification (optional)
# Generate via Warpcast developer tools or Farcaster Hub CLI.
# Only needed for Warpcast mini app discovery — not required for Base App.
FC_ACCOUNT_HEADER=
FC_ACCOUNT_PAYLOAD=
FC_ACCOUNT_SIGNATURE=

# ─── Optional — Demo Mode ───────────────────

# Set to "true" to show the demo banner on the site.
# Automatically enabled on Vercel deployments.
NEXT_PUBLIC_DEMO_MODE=false

# ─── Optional — URLs (auto-set by platform) ─

# Set automatically on Vercel — no action needed.
# For self-hosted: set to your deployment hostname.
VERCEL_URL=

# ─── Internal Defaults (do not change) ─────

# Base chain ID for Etherscan V2 and chain detection
BASE_CHAIN_ID=8453

# ─── Optional — Admin ─────────────────────

# Your Farcaster FID — gates access to /api/admin/*
ADMIN_FID=666666

# Admin API key — required to access /api/admin/* (api-keys, analytics, etc.)
# Set to a random string; pass as x-admin-key header to authenticate
ADMIN_KEY=

# ─── Optional — API Key Rate Limits ────────

# Default rate limits per tier (requests per minute)
# Override per-key via /api/admin/api-keys POST body
API_RATE_LIMIT_FREE=100
API_RATE_LIMIT_PRO=1000
API_RATE_LIMIT_ENTERPRISE=10000
