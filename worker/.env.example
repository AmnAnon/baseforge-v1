# ─── BaseForge Worker — Local Dev Environment ─────────────────────
# Copy this:  cp worker/.env.example worker/.env.local
# Populate from your Upstash + Neon dashboards.
# These are also needed on Vercel for the main app.

# Required: Upstash Redis
# Get from https://console.upstash.com → Redis Database
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your_token_here

# Required: Neon Postgres (serverless)
# Get from https://console.neon.tech → your project → connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: override metric server port
METRICS_PORT=3001
